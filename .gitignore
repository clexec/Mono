# Xcode
#
# gitignore contributors: remember to update Global/Xcode.gitignore, Objective-C.gitignore & Swift.gitignore

## User settings
xcuserdata/

## Xcode 8 and earlier
*.xcscmblueprint
*.xccheckout

## Xcode Patch
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
!*.xcodeproj/project.xcworkspace/
!*.xcworkspace/contents.xcworkspacedata
/*.gcno
**/xcshareddata/WorkspaceSettings.xcsettings

# Swift Package Manager
.build/
.swiftpm/

## Playgrounds
timeline.xctimeline
playground.xcworkspace

# CocoaPods
Pods/

# Carthage
Carthage/Build/

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Code Injection
iOSInjectionProject/

# macOS
.DS_Store

# API Keys (DO NOT COMMIT)
Config.swift
APIKeys.plist

# Build artifacts
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM

# Temporary files
*.swp
*~.nib
*.moved-aside
*.xcuserstate
*.xcscmblueprint

# App packaging
*.app
*.xcarchive

# Debugging
*.hmap

# IDEs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Node / Expo (if needed)
node_modules
.env
.expo
.rork
